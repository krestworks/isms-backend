model AutoServicePrice {
  id             String   @id @default(cuid())
  stationId      String
  serviceName    String
  category       String
  labourCost     Float    @default(0)
  partsEstimate  Float    @default(0)
  totalPrice     Float    @default(0)
  duration       String?
  warranty       String?
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AutoTechnician {
  id              String   @id @default(cuid())
  stationId       String
  name            String
  phone           String?
  specialization  String?
  experience      String?
  certifications  String?
  dailyRate       Float    @default(0)
  jobsCompleted   Int      @default(0)
  rating          Float    @default(0)
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ── Carwash ───────────────────────────────────────────────────────────────────

model CarwashSale {
  id            String   @id @default(cuid())
  stationId     String
  receiptNo     String
  date          DateTime
  vehicleReg    String
  washPackage   String
  attendant     String?
  paymentMethod String   @default("Cash")
  amount        Float    @default(0)
  status        String   @default("paid")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CarwashBooking {
  id          String   @id @default(cuid())
  stationId   String
  bookingRef  String
  date        DateTime
  time        String?
  client      String
  phone       String?
  vehicleReg  String
  washPackage String
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CarwashStaff {
  id              String   @id @default(cuid())
  stationId       String
  name            String
  phone           String?
  role            String   @default("Washer")
  shift           String   @default("Morning")
  rating          Float    @default(0)
  washesCompleted Int      @default(0)
  status          String   @default("on_duty")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CarwashQueue {
  id          String   @id @default(cuid())
  stationId   String
  ticketNo    String
  date        DateTime
  vehicleReg  String
  vehicleType String   @default("Sedan")
  washPackage String
  assignedTo  String?
  amount      Float    @default(0)
  status      String   @default("waiting")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CarwashPackage {
  id           String   @id @default(cuid())
  stationId    String
  name         String
  description  String?
  duration     Int      @default(30)
  price        Float    @default(0)
  vehicleTypes String   @default("All")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Business POS Module ───────────────────────────────────────────────────────

model BizBusiness {
  id            String   @id @default(cuid())
  stationId     String
  type          String   // mart | pharmacy | restaurant | bakery
  name          String
  taxRate       Float    @default(16)
  currency      String   @default("KES")
  receiptHeader String?
  receiptFooter String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([stationId, type])
}

model BizCategory {
  id         String   @id @default(cuid())
  businessId String
  name       String
  color      String?
  parentId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model BizProduct {
  id                   String   @id @default(cuid())
  businessId           String
  categoryId           String?
  categoryName         String?
  name                 String
  sku                  String?
  barcode              String?
  description          String?
  markedPrice          Float    @default(0)
  price                Float    @default(0)
  costPrice            Float    @default(0)
  unit                 String   @default("pcs")
  stockQty             Float    @default(0)
  reorderLevel         Float    @default(5)
  imageUrl             String?  @db.Text
  expiryDate           String?
  requiresPrescription Boolean  @default(false)
  status               String   @default("active")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model BizSupplier {
  id            String   @id @default(cuid())
  businessId    String
  name          String
  phone         String?
  email         String?
  address       String?
  contactPerson String?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BizPurchaseOrder {
  id           String   @id @default(cuid())
  businessId   String
  supplierId   String?
  supplierName String?
  orderRef     String
  orderDate    String
  expectedDate String?
  items        String   @db.LongText // JSON [{productId,productName,qty,unitCost,totalCost}]
  subtotal     Float    @default(0)
  totalAmount  Float    @default(0)
  status       String   @default("pending") // pending | received | partial | cancelled
  notes        String?
  receivedAt   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BizSale {
  id                 String   @id @default(cuid())
  businessId         String
  saleRef            String
  date               String
  items              String   @db.LongText // JSON [{productId,name,qty,unitPrice,discount,totalPrice}]
  subtotal           Float    @default(0)
  discount           Float    @default(0)
  taxRate            Float    @default(0)
  taxAmount          Float    @default(0)
  totalAmount        Float    @default(0)
  paymentMethod      String   @default("Cash")
  amountPaid         Float    @default(0)
  change             Float    @default(0)
  cashier            String?
  tableId            String?
  tableNo            String?
  notes              String?
  status             String   @default("paid") // paid | pending_payment | void | refunded
  // Pesapal gateway fields (M-Pesa / Card)
  pesapalTrackingId  String?
  pesapalStatus      String?  // pending | Completed | Failed | Invalid | Reversed
  customerPhone      String?
  pesapalRedirectUrl String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BizStockMovement {
  id          String   @id @default(cuid())
  businessId  String
  productId   String
  productName String
  type        String   // purchase_in | sale_out | adjustment | return | wastage
  qty         Float
  before      Float    @default(0)
  after       Float    @default(0)
  reference   String?
  notes       String?
  date        String
  createdAt   DateTime @default(now())
}

model BizExpense {
  id            String   @id @default(cuid())
  businessId    String
  date          String
  description   String
  amount        Float    @default(0)
  category      String?
  paymentMethod String   @default("Cash")
  recordedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model BizTable {
  id         String   @id @default(cuid())
  businessId String
  tableNo    String
  capacity   Int      @default(4)
  status     String   @default("available") // available | occupied | reserved
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([businessId, tableNo])
}

model BizKitchenOrder {
  id         String   @id @default(cuid())
  businessId String
  tableId    String?
  tableNo    String?
  orderRef   String
  items      String   @db.LongText // JSON
  status     String   @default("pending") // pending | preparing | ready | served
  notes      String?
  saleId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ── Clients & CRM ─────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  stationId String
  name      String
  phone     String?
  email     String?
  type      String   @default("Individual") // Individual | Corporate
  modules   String   @default("")           // comma-separated e.g. "Fuel,LPG"
  notes     String?
  totalSpent Float   @default(0)
  visits    Int      @default(0)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(cuid())
  stationId     String
  code          String
  module        String   @default("Fuel")
  discountType  String   @default("Percentage") // Percentage | Fixed
  discountValue Float    @default(0)
  minSpend      Float    @default(0)
  maxUses       Int      @default(0)      // 0 = unlimited
  usedCount     Int      @default(0)
  validFrom     String
  validTo       String
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([stationId, code])
}

model ClientOrder {
  id          String   @id @default(cuid())
  stationId   String
  clientId    String?
  clientName  String
  orderRef    String
  module      String   @default("Fuel") // Fuel | LPG | Water | Car Wash | Automotive | Business
  description String
  amount      Float    @default(0)
  paymentMethod String @default("Cash")
  status      String   @default("pending") // pending | processing | completed | cancelled
  orderDate   String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ── Station Settings ──────────────────────────────────────────────────────────

// Stores arbitrary JSON config blobs per station (e.g. section="business", section="vat")
model StationConfig {
  id        String   @id @default(cuid())
  stationId String
  section   String
  data      String   @db.LongText // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stationId, section])
}

model VatRate {
  id        String   @id @default(cuid())
  stationId String
  name      String
  rate      Float    @default(0)
  appliesTo String   @default("")
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Finance Module ─────────────────────────────────────────────────────────────

model FinanceRevenue {
  id            String   @id @default(cuid())
  stationId     String
  date          String
  module        String
  category      String
  description   String
  amount        Float    @default(0)
  paymentMethod String   @default("Cash")
  reference     String?
  status        String   @default("completed") // completed | pending
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FinanceExpense {
  id            String   @id @default(cuid())
  stationId     String
  date          String
  module        String   @default("General")
  category      String
  vendor        String?
  description   String
  amount        Float    @default(0)
  paymentMethod String   @default("Cash")
  approvedBy    String?
  status        String   @default("pending") // paid | pending | cancelled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FinanceBudget {
  id        String   @id @default(cuid())
  stationId String
  year      Int
  month     Int      // 1-12
  module    String
  metric    String   // "Revenue" | "Expenses"
  amount    Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stationId, year, month, module, metric])
}

// ── Reports Module ─────────────────────────────────────────────────────────────

model ReportTemplate {
  id        String   @id @default(cuid())
  stationId String
  name      String
  module    String   @default("All")
  frequency String   @default("daily")
  sections  String   @default("")
  status    String   @default("active")
  lastUsed  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneratedReport {
  id          String   @id @default(cuid())
  stationId   String
  templateId  String?
  title       String
  type        String   @default("daily")
  module      String   @default("All")
  period      String
  format      String   @default("PDF")
  generatedBy String
  fileSize    String?
  status      String   @default("completed")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduledReport {
  id         String   @id @default(cuid())
  stationId  String
  name       String
  type       String
  frequency  String
  modules    String   @default("All")
  recipients String
  lastRun    String?
  nextRun    String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
