generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Station {
  id        String    @id @default(cuid())
  name      String
  type      String    @default("Branch")
  status    String    @default("Active")
  city      String?
  address   String?
  phone     String?
  openedOn  DateTime?
  deletedAt DateTime?
  deletedBy String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userRoles       UserRole[]
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  category    String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

// stationId = "global" means the role applies across all stations
model UserRole {
  id        String @id @default(cuid())
  userId    String
  roleId    String
  stationId String @default("global")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, stationId])
}

// User-level permission overrides — granted=true adds, granted=false revokes
// stationId = "global" applies across all stations
model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  stationId    String   @default("global")
  granted      Boolean  @default(true)
  grantedBy    String?  // userId of the Manager/Admin who set this
  grantedAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId, stationId])
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  name             String
  phone            String?
  employeeId       String?
  isEmployee       Boolean   @default(false)
  activeRole       String    @default("Employee")
  homeLocation     String?
  status           String    @default("Active")
  loginAttempts    Int       @default(0)
  lockedUntil      DateTime?
  lastLogin        DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  auditLogs       AuditLog[]
  userRoles       UserRole[]
  userPermissions UserPermission[]
  refreshTokens   RefreshToken[]
  employee        Employee?
}

// One row per active session — supports multi-device and per-session revocation
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── HR Business Setup ─────────────────────────────────────────────────────────

// stationId = "global" means applicable across all stations
model Department {
  id          String   @id @default(cuid())
  name        String
  description String?
  stationId   String   @default("global")
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent    Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children  Department[] @relation("DeptTree")
  employees Employee[]
  jobTitles JobTitle[]

  @@unique([name, stationId])
}

model JobTitle {
  id           String   @id @default(cuid())
  title        String
  description  String?
  departmentId String?
  stationId    String   @default("global")
  grade        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@unique([title, stationId])
}

// Which modules are enabled per station; HR is seeded as enabled by default
model StationModule {
  id        String   @id @default(cuid())
  stationId String
  module    String
  isEnabled Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stationId, module])
}

// ── Employee Profile ──────────────────────────────────────────────────────────

model Employee {
  id               String    @id @default(cuid())
  userId           String    @unique
  employeeNumber   String    @unique
  stationId        String
  departmentId     String?
  jobTitleId       String?
  employmentType   String    @default("FullTime")
  contractType     String?
  startDate        DateTime
  endDate          DateTime?
  nationalId       String?
  dateOfBirth      DateTime?
  gender           String?
  address          String?   @db.Text
  emergencyContact String?   @db.Text
  bankDetails      String?   @db.Text
  salaryGrade      String?
  basicSalary      Float?
  status           String    @default("Active")
  terminatedAt     DateTime?
  terminationNote  String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user                User                 @relation(fields: [userId], references: [id])
  department          Department?          @relation(fields: [departmentId], references: [id])
  jobTitle            JobTitle?            @relation(fields: [jobTitleId], references: [id])
  attendance          Attendance[]
  leaveRequests       LeaveRequest[]
  leaveBalances       LeaveBalance[]
  shiftAssignments    ShiftAssignment[]
  disciplinaryRecords DisciplinaryRecord[]
  documents           EmployeeDocument[]
  payrolls            Payroll[]
  performanceTasks    PerformanceTask[]
}

// ── Shifts & Attendance ───────────────────────────────────────────────────────

model ShiftPattern {
  id        String   @id @default(cuid())
  name      String
  startTime String
  endTime   String
  stationId String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ShiftAssignment[]

  @@unique([name, stationId])
}

model ShiftAssignment {
  id             String   @id @default(cuid())
  employeeId     String
  shiftPatternId String
  date           DateTime
  stationId      String
  createdBy      String
  createdAt      DateTime @default(now())

  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shiftPattern ShiftPattern @relation(fields: [shiftPatternId], references: [id])

  @@unique([employeeId, date])
}

model Attendance {
  id         String    @id @default(cuid())
  employeeId String
  date       DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     String    @default("Present")
  note       String?
  recordedBy String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

// ── Leave Management ──────────────────────────────────────────────────────────

model LeaveType {
  id                String   @id @default(cuid())
  name              String
  daysAllowed       Int      @default(21)
  isPaid            Boolean  @default(true)
  stationId         String   @default("global")
  isActive          Boolean  @default(true)
  // Policy fields
  carryOver         Boolean  @default(false)
  carryOverMax      Int      @default(0)
  noticeDays        Int      @default(0)
  maxConsecutive    Int      @default(0)
  minTenureMonths   Int      @default(0)
  genderRestriction String?
  accrualType       String   @default("annual")
  excludeHolidays   Boolean  @default(true)
  excludeWeekends   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  requests LeaveRequest[]
  balances LeaveBalance[]

  @@unique([name, stationId])
}

model PublicHoliday {
  id          String   @id @default(cuid())
  name        String
  date        DateTime
  isRecurring Boolean  @default(true)
  stationId   String   @default("global")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeaveBalance {
  id          String @id @default(cuid())
  employeeId  String
  leaveTypeId String
  year        Int
  total       Int
  used        Int    @default(0)
  pending     Int    @default(0)

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  @@unique([employeeId, leaveTypeId, year])
}

model LeaveRequest {
  id          String    @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String?
  status      String    @default("Pending")
  approvedBy  String?
  approvedAt  DateTime?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])
}

// ── Employee Documents ─────────────────────────────────────────────────────────

model EmployeeDocument {
  id           String   @id @default(cuid())
  employeeId   String
  type         String
  fileName     String
  fileSize     Int      @default(0)
  fileData     String?  @db.LongText
  expiresOn    String?
  status       String   @default("valid")
  notes        String?  @db.Text
  caseId       String?
  uploadedBy   String
  uploadedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── Disciplinary ──────────────────────────────────────────────────────────────

model DisciplinaryRecord {
  id          String    @id @default(cuid())
  employeeId  String
  category    String    @default("Misconduct")
  offence     String?   @db.Text
  description String    @db.Text
  date        DateTime
  reportedBy  String?
  stage       String    @default("Informal Action")
  outcome     String?
  hearingDate DateTime?
  appeal      String?   @db.Text
  notes       String?   @db.Text
  recordedBy  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── Payroll ────────────────────────────────────────────────────────────────────

model Payroll {
  id                 String   @id @default(cuid())
  stationId          String
  employeeId         String
  month              String
  basicSalary        Float    @default(0)
  houseAllowance     Float    @default(0)
  transportAllowance Float    @default(0)
  overtimePay        Float    @default(0)
  grossPay           Float    @default(0)
  nhif               Float    @default(0)
  nssf               Float    @default(0)
  paye               Float    @default(0)
  otherDeductions    Float    @default(0)
  totalDeductions    Float    @default(0)
  netPay             Float    @default(0)
  status             String   @default("pending")
  payDate            String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month])
}

// ── Performance Tasks ─────────────────────────────────────────────────────────

model PerformanceTask {
  id          String    @id @default(cuid())
  stationId   String
  employeeId  String
  title       String
  category    String    @default("General")
  dueDate     String?
  status      String    @default("todo")
  priority    String    @default("medium")
  notes       String?   @db.Text
  rating      Int?
  assignedBy  String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ── Fuel Module ───────────────────────────────────────────────────────────────

model FuelTank {
  id                 String    @id @default(cuid())
  stationId          String
  name               String
  fuelType           String
  capacity           Float
  currentLevel       Float     @default(0)
  lastDipReading     Float?
  lastDeliveryDate   DateTime?
  lastDeliveryAmount Float?
  status             String    @default("operational")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sales           FuelSale[]
  deliveries      FuelDelivery[]
  reconciliations FuelReconciliation[]

  @@unique([name, stationId])
}

model FuelSale {
  id            String   @id @default(cuid())
  stationId     String
  tankId        String?
  pumpNumber    Int
  fuelType      String
  litres        Float
  pricePerLitre Float
  amount        Float
  discount      Float    @default(0)
  netAmount     Float
  attendant     String?
  paymentMethod String   @default("Cash")
  paymentStatus String   @default("paid")
  customer      String?
  receiptNo     String
  date          DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tank FuelTank? @relation(fields: [tankId], references: [id], onDelete: SetNull)
}

model FuelDelivery {
  id           String   @id @default(cuid())
  stationId    String
  tankId       String?
  litres       Float
  supplier     String?
  deliveryNote String?
  date         DateTime
  recordedBy   String?
  createdAt    DateTime @default(now())

  tank FuelTank? @relation(fields: [tankId], references: [id], onDelete: SetNull)
}

model FuelReconciliation {
  id                   String    @id @default(cuid())
  stationId            String
  date                 DateTime
  fuelType             String
  tankId               String?
  openingStock         Float
  deliveries           Float     @default(0)
  expectedSales        Float
  actualSales          Float
  closingStockExpected Float
  closingStockActual   Float
  variance             Float
  variancePct          Float
  status               String
  notes                String?
  approvedBy           String?
  approvedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tank FuelTank? @relation(fields: [tankId], references: [id], onDelete: SetNull)
}

model FuelProduct {
  id              String   @id @default(cuid())
  stationId       String
  fuelType        String
  buyingPrice     Float    @default(0)
  markedPrice     Float    @default(0)
  sellingPrice    Float    @default(0)
  reorderLevel    Float    @default(5000)
  supplier        String?
  supplierContact String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([stationId, fuelType])
}

// ── LPG Module ────────────────────────────────────────────────────────────────

model LpgCylinder {
  id             String    @id @default(cuid())
  stationId      String
  serialNo       String
  size           String
  weight         Float     @default(0)
  condition      String    @default("full")
  status         String    @default("available")
  buyingPrice    Float     @default(0)
  markedPrice    Float     @default(0)
  sellingPrice   Float     @default(0)
  supplier       String?
  lastRefillDate DateTime?
  location       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([serialNo, stationId])
}

model LpgSale {
  id            String   @id @default(cuid())
  stationId     String
  date          DateTime
  receiptNo     String
  customer      String?
  cylinderSize  String
  quantity      Int
  unitPrice     Float
  discount      Float    @default(0)
  totalAmount   Float
  paymentMethod String   @default("Cash")
  paymentStatus String   @default("paid")
  attendant     String?
  exchangeType  String   @default("Exchange")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LpgRefill {
  id           String   @id @default(cuid())
  stationId    String
  date         DateTime
  batchNo      String
  cylinderSize String
  quantity     Int
  costPerUnit  Float
  totalCost    Float
  supplier     String
  receivedBy   String?
  status       String   @default("pending")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LpgSupplier {
  id            String    @id @default(cuid())
  stationId     String
  name          String
  contactPerson String?
  phone         String?
  email         String?
  address       String?
  cylinderTypes String?
  paymentTerms  String    @default("Net 30")
  rating        Float     @default(0)
  status        String    @default("active")
  totalOrders   Int       @default(0)
  lastOrderDate DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([name, stationId])
}

model LpgOrder {
  id              String    @id @default(cuid())
  stationId       String
  orderNo         String
  date            DateTime
  client          String
  clientPhone     String?
  cylinderSize    String
  quantity        Int
  unitPrice       Float
  totalAmount     Float
  orderStatus     String    @default("pending")
  paymentStatus   String    @default("pending")
  paymentMethod   String    @default("Cash")
  processedBy     String?
  deliveredBy     String?
  deliveryAddress String?
  deliveryDate    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model LpgInvoice {
  id            String    @id @default(cuid())
  stationId     String
  invoiceNo     String
  date          DateTime
  dueDate       DateTime?
  client        String
  clientPhone   String?
  clientAddress String?
  items         String    @db.LongText
  subtotal      Float
  vatRate       Float     @default(16)
  vatAmount     Float
  discount      Float     @default(0)
  totalAmount   Float
  paymentStatus String    @default("pending")
  paymentMethod String    @default("Invoice")
  paidDate      DateTime?
  type          String    @default("invoice")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ── Water Module ──────────────────────────────────────────────────────────────

model WaterProduction {
  id             String   @id @default(cuid())
  stationId      String
  date           DateTime
  shift          String   @default("Morning")
  litresProduced Float
  litresWasted   Float    @default(0)
  netOutput      Float
  operator       String?
  machineId      String?
  status         String   @default("active")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WaterEquipment {
  id              String    @id @default(cuid())
  stationId       String
  name            String
  type            String
  serialNo        String?
  status          String    @default("operational")
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  location        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model WaterSale {
  id            String   @id @default(cuid())
  stationId     String
  date          DateTime
  receiptNo     String
  customer      String?
  litres        Float
  pricePerLitre Float
  discount      Float    @default(0)
  totalAmount   Float
  paymentMethod String   @default("Cash")
  paymentStatus String   @default("paid")
  attendant     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WaterOrder {
  id              String    @id @default(cuid())
  stationId       String
  orderNo         String
  date            DateTime
  client          String
  clientPhone     String?
  litres          Float
  pricePerLitre   Float
  totalAmount     Float
  orderStatus     String    @default("pending")
  paymentStatus   String    @default("pending")
  paymentMethod   String    @default("Cash")
  processedBy     String?
  deliveredBy     String?
  deliveryAddress String?
  deliveryDate    DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model WaterDistribution {
  id              String    @id @default(cuid())
  stationId       String
  date            DateTime
  vehicle         String?
  driver          String?
  destination     String?
  litresLoaded    Float
  litresDelivered Float     @default(0)
  variance        Float     @default(0)
  client          String?
  status          String    @default("active")
  departureTime   String?
  arrivalTime     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model WaterInvoice {
  id          String    @id @default(cuid())
  stationId   String
  invoiceNo   String
  date        DateTime
  dueDate     DateTime?
  client      String
  type        String    @default("TAX INVOICE")
  items       String    @db.LongText
  subtotal    Float
  vatAmount   Float
  totalAmount Float
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  subject   String
  detail    String   @db.Text
  ipAddress String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ── Automotive ────────────────────────────────────────────────────────────────

