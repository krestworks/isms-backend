# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://isms_user:your_password@localhost:3306/isms_db"

JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

PORT=5000
NODE_ENV=development

FRONTEND_URL=http://localhost:8080

BCRYPT_ROUNDS=12

# Africa's Talking — leave blank to stay in dev/sandbox mode
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=ISMS

# Pesapal payment gateway
# Get credentials from https://developer.pesapal.com/
PESAPAL_CONSUMER_KEY=your_consumer_key_here
PESAPAL_CONSUMER_SECRET=your_consumer_secret_here
PESAPAL_ENV=sandbox
# Must be publicly reachable (use ngrok in dev: ngrok http 5000)
PESAPAL_IPN_URL=https://yourdomain.com/api/v1/biz/payments/ipn
# Frontend URL Pesapal redirects to after card payment
PESAPAL_CALLBACK_URL=https://yourdomain.com/payment-complete
